# AWS Configuration
AWS_REGION=us-east-1

# Bedrock Knowledge Base ID (from AWS Console → Bedrock → Knowledge Bases)
KNOWLEDGE_BASE_ID=your-knowledge-base-id-here

# Foundation Model ARN for generation (Claude 3 Sonnet)
MODEL_ARN=arn:aws:bedrock:us-east-1::foundation-model/anthropic.claude-3-sonnet-20240229-v1:0

# Optional: AWS Profile (if using named profiles instead of default)
# AWS_PROFILE=default

# Server Configuration
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
